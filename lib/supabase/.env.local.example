# ==========================================
# 科普漫步 kepu-platform 环境变量配置模板
# 使用方式：复制此文件为 .env.local，填入真实值
# ==========================================

# ------------------------------------------
# Supabase 配置（必填）
# 获取地址：Supabase Dashboard → Project Settings → API
# ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------
# 应用配置
# ------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=科普漫步

# ------------------------------------------
# 【重要安全提示】
# - SUPABASE_SERVICE_ROLE_KEY 绝对不能暴露给前端，仅用于服务端 API Routes
# - .env.local 文件已加入 .gitignore，请勿提交到 Git 仓库
# - 生产环境在 Vercel 的 Environment Variables 界面配置上述变量
# ------------------------------------------
